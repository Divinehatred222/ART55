# Configuração do Supabase
# Pega esses valores em: Supabase Dashboard > Settings > API
# 
# Pra desenvolvimento local: copia este arquivo pra .env.local e preenche.
# Pra produção (Netlify): configura essas variáveis no painel da Netlify
# (Site settings > Environment variables).

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxx
